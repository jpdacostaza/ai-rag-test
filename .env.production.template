# Production Configuration Template
# Copy this to .env for production deployment

# === SECURITY CONFIGURATION ===
API_KEY=your-production-api-key-here-replace-this
JWT_SECRET=your-jwt-secret-for-tokens-change-this
DEV_API_KEY=dev-key-disable-in-production

# === LLM CONFIGURATION ===
DEFAULT_MODEL=llama3.2:3b
USE_OLLAMA=true
OLLAMA_BASE_URL=http://ollama:11434
LLM_TIMEOUT=180
MAX_REQUESTS_PER_MINUTE=60

# === DATABASE CONFIGURATION ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

CHROMA_HOST=chroma
CHROMA_PORT=8000
USE_HTTP_CHROMA=true
CHROMA_COLLECTION=user_memory
CHROMA_DB_DIR=./storage/chroma
CHROMA_TELEMETRY=false

# === EMBEDDING MODEL ===
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# === PERFORMANCE SETTINGS ===
CACHE_TTL=604800
SIMILARITY_THRESHOLD=0.92
POOL_SIZE=20

# === WATCHDOG CONFIGURATION ===
WATCHDOG_STARTUP_DELAY=10
WATCHDOG_CHECK_INTERVAL=30
WATCHDOG_TIMEOUT=5
WATCHDOG_MAX_RETRIES=3
WATCHDOG_ALERT_THRESHOLD=3

# === CORS & NETWORKING ===
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
BACKEND_PORT=8001
OPENWEBUI_PORT=3000

# === LOGGING CONFIGURATION ===
LOG_LEVEL=INFO
LOG_FORMAT=human
ENABLE_DEBUG_LOGGING=false

# === DEVELOPMENT FLAGS ===
DEBUG_MODE=false
ENABLE_MIDDLEWARE_DEBUG=false
DISABLE_AUTH_FOR_HEALTH=true

# === STORAGE PATHS ===
STORAGE_BASE_PATH=./storage
UPLOAD_MAX_SIZE=50MB
ALLOWED_FILE_TYPES=["txt","pdf","md","doc","docx"]

# === PRODUCTION NOTES ===
# 1. Change API_KEY to a secure random string
# 2. Change JWT_SECRET to a secure random string  
# 3. Set DEBUG_MODE=false for production
# 4. Update ALLOWED_ORIGINS with your actual domain
# 5. Consider enabling HTTPS and SSL certificates
# 6. Set appropriate LOG_LEVEL (INFO or WARNING for production)
